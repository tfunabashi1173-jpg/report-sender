{
	"name": "report-sender",
	"main": ".svelte-kit/cloudflare/_worker.js",
	"compatibility_date": "2024-01-01",
	"compatibility_flags": ["nodejs_compat"],
	"assets": {
		"directory": ".svelte-kit/cloudflare",
		"binding": "ASSETS"
	},
	"d1_databases": [
		{
			"binding": "DB",
			"database_name": "report-sender",
			"database_id": "049cd874-d7b5-4008-9e52-a3b2a27040e0"
		}
	]
}
